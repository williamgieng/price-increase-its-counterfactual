    "    d2_pred[\"y_hat_cf\"] = model.predict(d2_cf)\n",
    "    d2_pred[\"effect\"] = d2_pred[\"y_hat_obs\"] - d2_pred[\"y_hat_cf\"]\n",
    "\n",
    "    post_window = d2_pred.loc[d2_pred[\"week\"] >= intervention_date].head(26)\n",
